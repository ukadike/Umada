{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "umada/schemas/timeline.schema.json",
  "title": "UMADA Timeline",
  "description": "Validates data/timeline.json — a flat era list also held authoritatively in data/civilizational_ledger.json.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["era", "title", "status", "summary"],
    "additionalProperties": true,
    "properties": {
      "era": { "type": "integer", "minimum": 0 },
      "title": { "type": "string" },
      "status": { "type": "string" },
      "summary": { "type": "string" }
    }
  }
}
