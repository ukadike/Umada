{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "umada/schemas/visual_artifacts.schema.json",
  "title": "UMADA Visual Artifacts",
  "description": "Validates data/visual_artifacts.json — the structured form of 01_canon/VISUAL_CANON_REGISTRY.md.",
  "type": "object",
  "required": ["present", "awaiting_fragment"],
  "additionalProperties": true,
  "properties": {
    "present": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "status", "file", "alt_text"],
        "additionalProperties": true,
        "properties": {
          "artifact_id": { "type": "string" },
          "status": { "type": "string" },
          "file": { "type": "string" },
          "provenance": { "type": "string" },
          "title_on_plate": { "type": ["string", "null"] },
          "canon_implications": { "type": "string" },
          "episode_usage": { "type": "string" },
          "alt_text": { "type": "string" },
          "tactile_notes": { "type": "string" },
          "transcript_note": { "type": "string" },
          "caption_transcript": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["time", "text"],
              "additionalProperties": true,
              "properties": {
                "time": { "type": "string" },
                "text": { "type": "string" }
              }
            }
          },
          "open_questions": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "awaiting_fragment": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "status"],
        "additionalProperties": true,
        "properties": {
          "artifact_id": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    }
  }
}
